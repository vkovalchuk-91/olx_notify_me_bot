SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,web

TELEGRAM_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
WEB_REGISTRATION_BASE_URL=http://127.0.0.1:8000
USE_ASYNC_MODE=true
WORKERS_NUMBER=4
REQUEST_INTERVAL_MINUTES=15
INITIAL_REQUEST_DELAY_SECONDS=30
WEB_REGISTRATION_CODE_TTL_MINUTES=15
USE_SQLITE=true
LOCAL_DB_NAME=django_olx_notify.db
LOG_DB_NAME=job_logs.sqlite3
LOG_DB_TIMEOUT=20

# For local runserver without Docker (SQLite):
# USE_SQLITE=true

# For local runserver with Postgres:
# USE_SQLITE=false
# DB_HOST=localhost
# DB_NAME=olx_notify
# DB_USER=olx_user
# DB_PASSWORD=olx_password
# DB_PORT=5432

# For docker compose up: main app data uses this external Postgres config.
# Logs always use a separate local SQLite DB via LOG_DB_NAME.
DB_HOST=your-external-db-host
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_PORT=5432
DB_CONN_MAX_AGE=0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

INSTA_REQUEST_INTERVAL_MINUTES=30
