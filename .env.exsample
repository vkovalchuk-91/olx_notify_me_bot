TELEGRAM_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username_without_at

# Comma-separated Telegram user IDs with admin access
ADMIN_TELEGRAM_IDS=123456789

# Database: SQLite (local) OR PostgreSQL (production)
# Legacy Django env: USE_LOCAL_DB=true -> SQLite, USE_LOCAL_DB=false -> PostgreSQL
USE_SQLITE=true
LOCAL_DB_NAME=olx_notify.db

# When USE_SQLITE=false (or USE_LOCAL_DB=false):
# DB_HOST=your-external-db-host
# DB_NAME=your-db-name
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# DB_PORT=5432

USE_ASYNC_MODE=true
WORKERS_NUMBER=1
REQUEST_INTERVAL_MINUTES=15
INSTA_REQUEST_INTERVAL_MINUTES=30

# Optional: path to Chromium on Linux VM
# CHROME_BIN=/usr/bin/chromium
